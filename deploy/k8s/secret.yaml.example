apiVersion: v1
kind: Secret
metadata:
  name: gateway-secrets
  namespace: llm-gateway
type: Opaque
stringData:
  LLM_API_KEY: "<groq-or-openai-or-anthropic-key>"
  LANGFUSE_PUBLIC_KEY: "<langfuse-public-key>"
  LANGFUSE_SECRET_KEY: "<langfuse-secret-key>"
  REDIS_PASSWORD: "<random-strong-password>"
  # Add JWT_PUBLIC_KEY here for production auth (PR #6)
  # JWT_PUBLIC_KEY: |
  #   -----BEGIN PUBLIC KEY-----
  #   ...
  #   -----END PUBLIC KEY-----